        ]
      }
    location: "wtf-engine/crates/wtf-worker/tests.json"

# ============================================================================
# SECTION 6: IMPLEMENTATION TASK LIST
# ============================================================================

implementation_tasks:
  phase_0_research:
    parallelizable: true
    tasks:
      - task: "Read ADR-007 for TIMERS schema"
        parallel_group: "research"
        file: "/home/lewis/src/wtf-engine/docs/adr/ADR-007-sled-schema.md"
        done_when: "TimerData structure and key format documented"

      - task: "Examine ractor ActorCell for message sending"
        parallel_group: "research"
        file: "/home/lewis/src/wtf-engine/crates/wtf-actor/src/messages.rs"
        done_when: "TimerFired message structure understood"

  phase_1_tests_first:
    parallelizable: false
    gate_required: "gate_0_research"
    tasks:
      - task: "Write timer module tests"
        file: "/home/lewis/src/wtf-engine/crates/wtf-worker/src/timer_tests.rs"
        what: |
          mod tests {
            use super::*;
            use std::sync::Arc;
            use tempfile::TempDir;

            fn create_test_db() -> Arc<sled::Db> {
              let temp_dir = TempDir::new().unwrap();
              Arc::new(sled::open(temp_dir.path()).unwrap())
            }

            #[test]
            fn test_timer_struct_creation() {
              let db = create_test_db();
              let task = TimerBackgroundTask::new(db.clone(), 100);
              assert!(task.is_ok());
            }
          }
        done_when: "Test file exists, tests fail (red phase)"

  phase_2_implementation:
    parallelizable: false
    gate_required: "gate_1_tests"
    tasks:
      - task: "Implement TimerBackgroundTask struct"
        file: "/home/lewis/src/wtf-engine/crates/wtf-worker/src/timer.rs"
        what: |
          pub struct TimerBackgroundTask {
              storage: Arc<sled::Db>,
              check_interval_ms: u64,
          }

          impl TimerBackgroundTask {
              pub fn new(storage: Arc<sled::Db>, check_interval_ms: u64) -> Result<Self, TimerError> {
                  if check_interval_ms == 0 {
                      return Err(TimerError::InvalidInterval);
                  }
                  Ok(Self { storage, check_interval_ms })
              }
          }
        patterns_to_use:
          - "Result<T, TimerError> for construction"
          - "Arc<sled::Db> for shared ownership"
        done_when: "Struct compiles"

      - task: "Implement run() main loop"
        file: "/home/lewis/src/wtf-engine/crates/wtf-worker/src/timer.rs"
        what: |
          pub async fn run(&self) -> Result<(), TimerError> {
              let interval = tokio::time::Duration::from_millis(self.check_interval_ms);
              let mut ticker = tokio::time::interval(interval);
              
              loop {
                  ticker.tick().await;
                  if let Err(e) = self.check_and_fire_timers().await {
                      tracing::error!(error = %e, "Error checking timers");
                  }
              }
          }
        depends_on: "Implement TimerBackgroundTask struct"
        done_when: "run() loop compiles and runs"

      - task: "Implement get_expired_timers()"
        file: "/home/lewis/src/wtf-engine/crates/wtf-worker/src/timer.rs"
        what: |
          pub fn get_expired_timers(&self) -> Result<Vec<TimerData>, TimerError> {
              let timers = self.storage.open_tree(TIMERS)?;
              let now = chrono::Utc::now().timestamp();
              
              let mut expired = Vec::new();
              for item in timers.iter() {
                  let (key, value) = item.map_err(|e| TimerError::SledError(e))?;
                  let timer: TimerData = serde_json::from_slice(&value)
                      .map_err(|e| TimerError::JsonError(e))?;
                  if timer.fire_at <= now {
                      expired.push(timer);
                  }
              }
              Ok(expired)
          }
        depends_on: "Implement TimerBackgroundTask struct"
        done_when: "Function compiles and returns expired timers"

      - task: "Implement delete_timer()"
        file: "/home/lewis/src/wtf-engine/crates/wtf-worker/src/timer.rs"
        what: |
          pub fn delete_timer(&self, invocation_id: &str, seq: u32) -> Result<(), TimerError> {
              let timers = self.storage.open_tree(TIMERS)?;
              let key = format!("{}:{}", invocation_id, seq);
              timers.remove(key.as_bytes())
                  .map_err(|e| TimerError::SledError(e))?;
              Ok(())
          }
        depends_on: "Implement TimerBackgroundTask struct"
        done_when: "delete_timer removes timer from database"

      - task: "Implement fire_timer()"
        file: "/home/lewis/src/wtf-engine/crates/wtf-worker/src/timer.rs"
        what: |
          pub async fn fire_timer(&self, timer: TimerData) -> Result<(), TimerError> {
              tracing::trace!(
                  invocation_id = %timer.invocation_id,
                  seq = timer.seq,
                  "Firing timer"
              );
              
              // TODO: Look up workflow instance actor and send TimerFired message
              // This will be wired to the actor system in a later bead
              
              Ok(())
          }
        depends_on: "Implement TimerBackgroundTask struct"
        done_when: "fire_timer() compiles and logs timer firing"

      - task: "Implement check_and_fire_timers()"
        file: "/home/lewis/src/wtf-engine/crates/wtf-worker/src/timer.rs"
        what: |
          pub async fn check_and_fire_timers(&self) -> Result<(), TimerError> {
              let expired = self.get_expired_timers()?;
              
              for timer in expired {
                  // Delete first, then fire
                  if let Err(e) = self.delete_timer(&timer.invocation_id, timer.seq) {
                      tracing::warn!(
                          error = %e,
                          invocation_id = %timer.invocation_id,
                          "Failed to delete timer, skipping fire"
                      );
                      continue;
                  }
                  
                  if let Err(e) = self.fire_timer(timer).await {
                      tracing::error!(
                          error = %e,
                          "Failed to fire timer"
                      );
                      // Continue to next timer - don't stop
                  }
              }
              
              Ok(())
          }
        depends_on: "Implement get_expired_timers, delete_timer, fire_timer"
        done_when: "check_and_fire_timers processes all expired timers"

  phase_3_integration:
    parallelizable: false
    gate_required: "gate_2_implementation"
    tasks:
      - task: "Wire TimerFired message to actor system"
        file: "/home/lewis/src/wtf-engine/crates/wtf-worker/src/timer.rs"
        what: "Look up workflow instance actor and send TimerFired message"
        done_when: "TimerFired is actually sent to workflow instance"

  phase_4_verification:
    parallelizable: true
    gate_required: "gate_3_integration"
    tasks:
      - task: "Run moon run :ci"
        parallel_group: "verification"
        done_when: "All tests pass, no clippy warnings"

      - task: "Manual verification with test timer"
        parallel_group: "verification"
        commands:
          - "cargo test --package wtf-worker"
        expected: "All timer tests pass"

# ============================================================================
# SECTION 7: FAILURE MODES & DEBUGGING GUIDE
# ============================================================================

failure_modes:
  - symptom: "TimerBackgroundTask::new() returns InvalidInterval error"
    likely_cause: "check_interval_ms passed as 0"
    where_to_look:
      - file: "wtf-worker/src/timer.rs"
        function: "TimerBackgroundTask::new"
        what_to_check: "Validate check_interval_ms > 0"
    fix_pattern: "Pass non-zero interval value"

  - symptom: "get_expired_timers() returns empty even with expired timers"
    likely_cause: "Timer fire_at stored as wrong timezone (UTC vs local)"
    where_to_look:
      - file: "wtf-storage/src/timers.rs"
        function: "timer creation"
        what_to_check: "Ensure fire_at stored as Unix timestamp UTC"
    fix_pattern: "Use chrono::Utc::now().timestamp() for comparison"

  - symptom: "Timers not being deleted after firing"
    likely_cause: "delete_timer called before fire_timer completes"
    where_to_look:
      - file: "wtf-worker/src/timer.rs"
        function: "check_and_fire_timers"
        what_to_check: "Verify delete happens before fire"
    fix_pattern: "Reorder: delete first, then fire"

  - symptom: "run() loop stops after first tick"
    likely_cause: "ticker.tick() called incorrectly"
    where_to_look:
      - file: "wtf-worker/src/timer.rs"
        function: "run"
        what_to_check: "Use tokio::time::interval correctly"
    fix_pattern: "Use .tick().await in loop"

debugging_commands:
  - scenario: "When timers aren't being found"
    run: "RUST_LOG=trace cargo test test_get_expired 2>&1 | grep -i timer"
    look_for: "Trace logs showing timer scan and deserialization"
  - scenario: "When actor message fails"
    run: "RUST_LOG=error cargo test 2>&1 | grep -i actor"
    look_for: "Error messages from ractor"

