# ============================================================================

e2e_tests:
  pipeline_test:
    name: "test_full_timer_firing_pipeline"
    description: "Create timer -> wait -> verify timer fired and deleted"

    setup:
      files_to_create:
        - path: "/tmp/wtf-timer-test-db"
          content: ""  # Temporary sled database directory
      environment:
        - "RUST_LOG=trace"

    execute:
      command: "cargo test --package wtf-worker timer -- --nocapture 2>&1"
      timeout_ms: 30000

    verify:
      exit_code: 0
      stdout_contains:
        - "test result: ok"

  e2e_scenarios:
    - name: "e2e_timer_polling_loop"
      description: "Verify run() loop polls at correct interval"
      steps:
        - action: "Create TimerBackgroundTask with 50ms interval"
          verify: "Task created successfully"
        - action: "Spawn run() in background"
          verify: "Loop is running"
        - action: "Wait 200ms and check poll count"
          verify: "Approximately 4 polls occurred (200/50)"

# ============================================================================
# SECTION 5.5: VERIFICATION CHECKPOINTS
# ============================================================================

