# SECTION 10: AI IMPLEMENTATION HINTS
# ============================================================================

ai_hints:
  do:
    - "Use Result<T, TimerError> for all public API functions"
    - "Use tokio::time::interval for periodic polling in run()"
    - "Use chrono::Utc::now().timestamp() for current Unix time"
    - "Use serde_json::from_slice for deserializing TimerData"
    - "Use tracing::trace! for logging timer operations"
    - "Continue processing other timers if one fails"
    - "Delete timer BEFORE firing to ensure at-most-once semantics"

  do_not:
    - "Do NOT use unwrap() or expect() on fallible operations"
    - "Do NOT use panic! for error handling"
    - "Do NOT block the async run() loop with sync operations"
    - "Do NOT use std::time::SystemTime (use chrono for UTC)"
    - "Do NOT assume timer actor always exists (log and skip)"

  code_patterns:
    - name: "Async background loop with interval"
      use_when: "Implementing run() that polls periodically"
      example: |
        pub async fn run(&self) -> Result<(), TimerError> {
            let interval = tokio::time::Duration::from_millis(self.check_interval_ms);
            let mut ticker = tokio::time::interval(interval);
            loop {
                ticker.tick().await;
                if let Err(e) = self.check_and_fire_timers().await {
                    tracing::error!(error = %e, "Timer check failed");
                }
            }
        }

    - name: "Iterator-based tree scan with early exit"
      use_when: "get_expired_timers() scanning TIMERS"
      example: |
        for item in timers.iter() {
            let (key, value) = item.map_err(TimerError::SledError)?;
            let timer: TimerData = serde_json::from_slice(&value)
                .map_err(TimerError::JsonError)?;
            if timer.fire_at <= now {
                expired.push(timer);
            }
        }

  constitution:
    - "Zero unwrap law: All fallible operations return Result"
    - "Functional first: Prefer map/and_then over if-else chains"
    - "Moon only: Use moon for all build/test commands"
    - "Test first: Tests must exist before implementation"
    - "Continue on failure: One bad timer should not stop others"
