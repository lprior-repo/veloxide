# ============================================================================
# BEAD: timer-task - Implement TimerBackgroundTask for workflow timer firing
# ============================================================================

id: "intent-wtf-timer-001"
title: "timer: Implement TimerBackgroundTask struct and run loop"
type: "feature"
priority: 1
effort_estimate: "2hr"
labels: ["wtf-worker", "timer", "background-task"]

# ============================================================================
# SECTION 0: CLARIFICATION MARKERS
# ============================================================================

clarification_status: "RESOLVED"

resolved_clarifications:
  - question: "How does fire_timer() send to workflow instance - via ractor actor message?"
    answer: "Yes, use ractor::ActorCell to send TimerFired message to workflow instance actor"
    decided_by: "ADR-003 and ADR-006 define ractor-based actor model"
    date: "2026-03-20"
  - question: "What is the error handling strategy for timer operations?"
    answer: "Use Result<T, Box<dyn std::error::Error>> and propagate errors; log and continue on individual timer failures"
    decided_by: "ADR-010 error handling taxonomy"
    date: "2026-03-20"
  - question: "Should run() loop run forever or have a shutdown signal?"
    answer: "run() runs in tokio loop with graceful shutdown on drop; check_interval_ms controls polling frequency"
    decided_by: "ADR-006 master orchestrator hierarchy"
    date: "2026-03-20"

assumptions:
  - assumption: "sled::Db is already opened and accessible via Arc<sled::Db>"
    validation_method: "Check wtf-storage/src/lib.rs for Db initialization"
    risk_if_wrong: "TimerBackgroundTask cannot be constructed"
  - assumption: "TimerFired message type exists in wtf-actor"
    validation_method: "Check wtf-actor/src/messages.rs for TimerFired definition"
    risk_if_wrong: "Cannot send timer messages to workflow instances"
  - assumption: "TIMERS tree constant is defined in wtf-storage"
    validation_method: "Check ADR-007 schema for TIMERS constant"
    risk_if_wrong: "Cannot query or delete timers from correct tree"

# ============================================================================
# SECTION 1: EARS REQUIREMENTS
# ============================================================================

ears_requirements:
  ubiquitous:
    - "THE SYSTEM SHALL use sled TIMERS tree for timer persistence"
    - "THE SYSTEM SHALL log all timer firing events at trace level"
    - "THE SYSTEM SHALL continue processing remaining timers if one fails"

  event_driven:
    - trigger: "WHEN check_interval_ms elapses"
      shall: "THE SYSTEM SHALL query for expired timers"
    - trigger: "WHEN a timer fire_at time has passed"
      shall: "THE SYSTEM SHALL delete timer from TIMERS tree"
    - trigger: "WHEN a timer expires"
      shall: "THE SYSTEM SHALL send TimerFired message to workflow instance actor"

  state_driven:
    - state: "WHILE run() loop is active"
      shall: "THE SYSTEM SHALL poll for expired timers at check_interval_ms intervals"

  unwanted:
    - condition: "IF timer firing fails for one workflow"
      shall_not: "THE SYSTEM SHALL NOT stop processing other timers"
      because: "One bad timer should not block others"
    - condition: "IF database error occurs"
      shall_not: "THE SYSTEM SHALL NOT panic or exit the run loop"
      because: "Background task must be resilient"

# ============================================================================
# SECTION 2: KIRK CONTRACTS
# ============================================================================

contracts:
  preconditions:
    auth_required: false
    required_inputs:
      - field: "storage"
        type: "Arc<sled::Db>"
        constraints: "Must be valid open sled database"
        example_valid: "Arc::new(sled::open(\"data\").unwrap())"
      - field: "check_interval_ms"
        type: "u64"
        constraints: "Must be > 0, reasonable range 10-60000ms"
        example_valid: "100"
        example_invalid: "0"
    system_state:
      - "sled TIMERS tree must be accessible"

  postconditions:
    state_changes:
      - "Expired timers are deleted from TIMERS tree"
      - "TimerFired messages are sent to workflow instance actors"
    return_guarantees:
      - field: "run()"
        guarantee: "Never returns normally; runs until dropped or error"
    side_effects:
      - "Deletes timers from sled database"
      - "Sends actor messages to workflow instances"

  invariants:
    - "Timer keys follow format invocation_id:seq"
    - "fire_at timestamp is compared against current Unix time"
    - "check_interval_ms determines polling frequency"

# ============================================================================
# SECTION 2.5: RESEARCH REQUIREMENTS
# ============================================================================

research_requirements:
  files_to_read:
    - path: "/home/lewis/src/wtf-engine/docs/adr/ADR-007-sled-schema.md"
      what_to_extract: "TIMERS tree schema, key encoding, TimerData structure"
      document_in: "research.md"
    - path: "/home/lewis/src/wtf-engine/crates/wtf-actor/src/messages.rs"
      what_to_extract: "TimerFired message structure and ActorCell pattern"
      document_in: "research.md"
    - path: "/home/lewis/src/wtf-engine/crates/wtf-storage/src/timers.rs"
      what_to_extract: "Existing timer storage functions if any"
      document_in: "research.md"

  patterns_to_find:
    - pattern: "impl.*ActorCell"
      purpose: "Understand how to send messages to actors"
      expected_locations: "wtf-actor/src/**/*.rs"
    - pattern: "TIMERS.*="
      purpose: "Find TIMERS constant definition"
      expected_locations: "wtf-storage/src/**/*.rs"

  research_questions:
    - question: "How does TimerFired message carry invocation_id for routing?"
      answered: false
    - question: "What is the ractor pattern for looking up workflow instance actor?"
      answered: false

# ============================================================================
# SECTION 3: INVERSION ANALYSIS
# ============================================================================

inversions:
  security_failures:
    - failure: "Malformed timer data in database could cause panic"
      prevention: "Use serde_json::from_slice with Result type, skip invalid timers"
      test_for_it: "test_malformed_timer_data_does_not_crash"

  data_integrity_failures:
    - failure: "Timer deleted but message send fails, causing lost timer"
      prevention: "Delete AFTER successful send, or use transaction"
      test_for_it: "test_timer_not_deleted_if_send_fails"

  integration_failures:
    - failure: "ActorCell lookup fails for expired timer invocation_id"
      prevention: "Log error and continue to next timer; do not crash"
      test_for_it: "test_invalid_invocation_id_continues_processing"

# ============================================================================
# SECTION 4: ATDD ACCEPTANCE TESTS
# ============================================================================

acceptance_tests:
  happy_paths:
    - name: "test_timer_struct_creation"
      given: "Valid sled database and check_interval_ms"
      when: "TimerBackgroundTask::new() is called"
      then:
        - "Returns Ok(TimerBackgroundTask)"
        - "storage and check_interval_ms fields are set correctly"

    - name: "test_get_expired_timers_returns_fired_timers"
      given: "Timer with fire_at in the past"
      when: "get_expired_timers() is called"
      then:
        - "Returns Vec containing the timer"
        - "Timer data is correctly deserialized"

    - name: "test_no_expired_timers_when_all_future"
      given: "All timers have fire_at in the future"
      when: "get_expired_timers() is called"
      then:
        - "Returns empty Vec"

  error_paths:
    - name: "test_delete_nonexistent_timer_continues"
      given: "Timer key does not exist"
      when: "delete_timer() is called"
      then:
        - "Returns Ok(()) (idempotent delete)"
        - "Does not error"

    - name: "test_malformed_timer_json_skipped"
      given: "Timer with invalid JSON value"
      when: "get_expired_timers() is called"
      then:
        - "Skips malformed timer"
        - "Returns remaining valid timers"

  edge_cases:
    - name: "test_empty_timers_tree"
      scenario: "TIMERS tree is empty"
      input: "Empty database"
      expected: "get_expired_timers returns empty vec"

    - name: "test_exactly_current_time"
      scenario: "Timer fire_at equals current time"
      input: "Timer with fire_at = now"
      expected: "Timer is considered expired and returned"

# ============================================================================
